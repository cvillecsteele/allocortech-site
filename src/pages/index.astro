      <source src="https://cdn.prod.website-files.com/6862be609b8104b1f6d09708%2F697bd671012f339e06724627_allocortech%20Landing%20Page%20Hero%20%28smaller%29%20%281%29_webm.webm" type="video/webm" />
    </video>
    <div class="hero-grad-top" aria-hidden="true"></div>
    <div class="hero-grad-bottom" aria-hidden="true"></div>
    <div class="hero-grid" aria-hidden="true"></div>
    <div class="hero-vignette" aria-hidden="true"></div>
    <div class="hero-reticle" aria-hidden="true">
      <div class="hero-reticle-circle"></div>
    </div>

    <div class="container hero-content" style="padding-top: 2rem; padding-bottom: 4rem;">
      <div style="max-width: 800px;" class="hero-text-delayed">
        <div class="hero-badge fade-up">
          <span class="hero-badge-dot" aria-hidden="true"></span>
          Taurus AEX Motor Controller: Now Available
        </div>

        <div class="hero-eyebrow fade-up">
          Power Electronics · Avionics · Virginia, USA
        </div>

        <h1 class="fade-up" style="font-size: clamp(2.8rem, 2rem + 4.5vw, 6.5rem); font-weight: 700; letter-spacing: -0.04em; line-height: 0.97; margin-bottom: 1.5rem;">
          Building a<br><span class="amber">next-gen</span><br>vehicle platform?
        </h1>

        <p class="lead fade-up" style="max-width: 52ch;">
          When reliability is non-negotiable and performance makes all the difference, our power system solutions lead the way in uncrewed systems, critical maritime operations, and aerospace &amp; defense.
        </p>

        <div class="hero-ctas fade-up">
          <a href="/contact" class="btn btn-primary">Talk to Sales</a>
          <a href="/products" class="btn btn-ghost">View Products</a>
        </div>
      </div>

      <div class="hero-stats fade-up">
        {stats.map(({ value, label, icon }) => (
          <div class="hero-stat-item">
            <img src={icon} alt="" class="hero-stat-icon" aria-hidden="true" />
