    <div class="marquee-track">
      {/* Two copies for seamless loop */}
      {[...partners, ...partners].map(({ name, logo, invert }) => (
        <img src={logo} alt={name} loading="lazy" data-invert={invert || undefined} />
      ))}
    </div>
  </div>

  <!-- ── Products ──────────────────────────────────────── -->
  <section class="section" style="padding-top: 5rem;">
    <div class="container">
      <div style="display: flex; justify-content: space-between; align-items: flex-end; flex-wrap: wrap; gap: 1.5rem; margin-bottom: 3rem;">
        <div>
          <div class="section-label">01 / Products</div>
          <h2>What we make</h2>
        </div>
        <a href="/products" class="btn btn-ghost" style="white-space: nowrap; flex-shrink: 0;">All products →</a>
      </div>

      <div class="product-carousel" id="product-carousel" style="--carousel-duration: 5000ms;">
        <div class="carousel-track-wrap">
          <div class="carousel-track" id="carousel-track">
            {featuredProducts.map((product) => (
              <a href={`/products/${product.id}`} class="product-card">
                {productCardImages[product.id] && (
                  <div class="product-card-img-wrap">
                    <img src={productCardImages[product.id]} alt={product.data.title} class="product-card-img" loading="lazy" />
                  </div>
                )}
                <div class="product-card-category">{product.data.category}</div>
                <div class="product-card-name">{product.data.title}</div>
                <p class="product-card-tagline">{product.data.tagline}</p>
                <div class="product-card-specs">
                  {product.data.keySpecs.slice(0, 3).map((spec) => (
                    <div class="product-card-spec">
                      <span class="product-card-spec-label">{spec.label}</span>
                      <span class="product-card-spec-value">{spec.value}</span>
                    </div>
                  ))}
                </div>
                <div class="product-card-link">View specs <span aria-hidden="true">→</span></div>
              </a>
            ))}
          </div>
        </div>
        <div class="carousel-controls">
          <button class="carousel-btn" id="carousel-prev" aria-label="Previous">←</button>
          <div class="carousel-indicators" id="carousel-dots"></div>
          <button class="carousel-btn" id="carousel-next" aria-label="Next">→</button>
        </div>
      </div>

      <script>
        (function () {
          const carousel = document.getElementById('product-carousel') as HTMLElement | null;
          const track    = document.getElementById('carousel-track') as HTMLElement | null;
          const dotsWrap = document.getElementById('carousel-dots') as HTMLElement | null;
          if (!carousel || !track || !dotsWrap) return;

          const cards    = Array.from(track.querySelectorAll<HTMLElement>('.product-card'));
          const DURATION = 5000; // ms — single source of truth for both JS timer and CSS animation

          // Keep CSS variable in sync so the animation duration matches exactly
          carousel.style.setProperty('--carousel-duration', DURATION + 'ms');

          function visibleCount() {
            const w = window.innerWidth;
            if (w <= 580) return 1;
            if (w <= 900) return 2;
            return 3;
          }

          let current = 0;
          let timer: ReturnType<typeof setTimeout> | null = null;

          function maxIndex() { return Math.max(0, cards.length - visibleCount()); }

          function cardStride() {
            // Width of one card slot (card width + gap). Measure after layout.
            const w = cards[0]?.offsetWidth ?? 0;
            return w + 1; // 1px gap
          }

          function translate(idx: number) {
            track.style.transform = `translateX(-${idx * cardStride()}px)`;
          }

          // Force CSS animation restart on the active dot
          function activateDot(dot: Element) {
            dot.classList.remove('active');
            // Void read forces a style reflow so the browser treats the re-add as fresh
            void (dot as HTMLElement).offsetWidth;
            dot.classList.add('active');
          }

          function updateDots() {
            dotsWrap.querySelectorAll('.carousel-dot').forEach((dot, i) => {
              if (i === current) {
                activateDot(dot);
              } else {
                dot.classList.remove('active');
              }
            });
          }

          function goTo(idx: number, resetAuto = false) {
            current = Math.max(0, Math.min(idx, maxIndex()));
            translate(current);
            updateDots();
            if (resetAuto) scheduleNext();
          }

          function advance() {
            current = current >= maxIndex() ? 0 : current + 1;
            translate(current);
            updateDots();
            scheduleNext();
          }

          // Use setTimeout (not setInterval) so each tick is scheduled fresh —
          // eliminates accumulated drift and makes pause/resume trivially exact.
          function scheduleNext() {
            if (timer) clearTimeout(timer);
            timer = setTimeout(advance, DURATION);
          }

          function pause() {
            if (timer) { clearTimeout(timer); timer = null; }
          }

          function buildDots() {
            dotsWrap.innerHTML = '';
            const count = maxIndex() + 1;
            for (let i = 0; i < count; i++) {
              const dot = document.createElement('button');
              dot.className = 'carousel-dot';
              dot.setAttribute('aria-label', `Go to slide ${i + 1}`);
              dot.addEventListener('click', () => goTo(i, true));
              dotsWrap.appendChild(dot);
            }
            updateDots();
          }

          // Nav
          document.getElementById('carousel-prev')?.addEventListener('click', () => {
            goTo(current <= 0 ? maxIndex() : current - 1, true);
          });
          document.getElementById('carousel-next')?.addEventListener('click', () => {
            goTo(current >= maxIndex() ? 0 : current + 1, true);
          });

          // Pause/resume on hover — also restart dot animation on resume so it's
          // always in sync with the fresh setTimeout we schedule
          carousel.addEventListener('mouseenter', pause);
          carousel.addEventListener('mouseleave', () => {
            activateDot(dotsWrap.querySelectorAll('.carousel-dot')[current]);
            scheduleNext();
          });

          // Touch swipe
          let touchX = 0;
          carousel.addEventListener('touchstart', (e) => { touchX = e.touches[0].clientX; }, { passive: true });
          carousel.addEventListener('touchend', (e) => {
            const dx = e.changedTouches[0].clientX - touchX;
            if (Math.abs(dx) > 40) goTo(dx < 0 ? current + 1 : current - 1, true);
          }, { passive: true });

          // Resize
          let resizeTO: ReturnType<typeof setTimeout>;
          window.addEventListener('resize', () => {
            clearTimeout(resizeTO);
            resizeTO = setTimeout(() => {
              buildDots();
              translate(Math.min(current, maxIndex()));
            }, 150);
          });

          buildDots();
          scheduleNext();
        })();
      </script>
    </div>
  </section>

  <!-- ── Platforms We Power ────────────────────────────── -->
  <div style="border-top: 1px solid var(--border-subtle); border-bottom: 1px solid var(--border-subtle);">
