  { domain: 'Hybrid-Powered Systems',               desc: 'Electric and hybrid-electric powertrain expertise across power distribution, battery management, and charging for air, land, and sea platforms.', img: '/images/applications/application-2.webp' },
  { domain: 'Electric & Legacy Watercraft',          desc: 'Marinized power distribution, motor controllers, and C3 hubs for next-generation electric vessels and hybrid maritime platforms.', img: '/images/applications/application-3.webp' },
  { domain: 'Technology Demonstrators',              desc: 'Accelerated prototype timelines using proven power electronics IP. From first-article hardware to flight-test-ready systems in weeks.', img: '/images/applications/application-4.webp' },
