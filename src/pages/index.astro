  'clio':       '/images/products/clio.webp',
  'comet-fts':  '/images/products/comet-fts.webp',
  'atlas':      '/images/products/atlas.webp',
  'dauphine':   '/images/products/dauphine.webp',
  'lohner':     '/images/products/lohner.webp',
  'hornet':     '/images/products/hornet.webp',
