      <div class="section-label" style="margin-bottom: 1.75rem;">Trusted by leading aerospace and defense programs</div>
      <div class="partner-grid">
        {partners.map(({ name, logo }) => (
          <img src={logo} alt={name} class="partner-logo" loading="lazy" title={name} />
