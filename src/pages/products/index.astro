---
import BaseLayout from '@/layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

const allProducts = await getCollection('products');
const sorted = allProducts.sort((a, b) => a.data.order - b.data.order);

const categories = [
  'Motor Controller',
  'Communication & Power Distribution',
  'Flight Termination System',
  'Air Data & Flight Control',
  'Power & Energy',
] as const;

type Category = typeof categories[number];

const byCategory: Record<string, typeof sorted> = {};
for (const cat of categories) {
  byCategory[cat] = sorted.filter(p => p.data.category === cat);
}

const productCardImages: Record<string, string> = {
  'taurus-400': '/images/products/taurus-400-nobg.webp',
  'taurus-ae':  '/images/products/taurus-ae.webp',
  'taurus-aex': '/images/products/taurus-aex.webp',
  'taurus-c60': '/images/products/taurus-c60.webp',
  'clio':       '/images/products/clio.webp',
  'comet-fts':  '/images/products/comet-fts.webp',
  'atlas':      '/images/products/atlas.webp',
  'dauphine':   '/images/products/dauphine.webp',
  'lohner':     '/images/products/lohner.webp',
  'hornet':     '/images/products/hornet.webp',
};

const categoryBanners: Record<string, string> = {
  'Motor Controller':                   '/images/products/category-motor-controllers.webp',
  'Communication & Power Distribution': '/images/products/category-comms-power.webp',
  'Flight Termination System':          '/images/products/category-fts.webp',
  'Air Data & Flight Control':          '/images/products/category-flight-control.webp',
  'Power & Energy':                     '/images/products/category-comms-power.webp',
};
---

<BaseLayout
  title="Products"
  description="Allocortech's complete family of COTS and MOTS motor controllers, avionics, power distribution, and flight termination systems."
>
  <!-- Page Hero -->
  <div class="page-hero">
    <img src="/images/hero/products-bg.webp" alt="" class="page-hero-bg" aria-hidden="true" />
    <div class="container">
      <div class="section-label">Products</div>
      <h1 style="margin-bottom: 1rem;">Innovative solutions for<br>next-gen vehicles</h1>
      <p class="lead" style="max-width: 56ch;">
        Safety-critical components designed for demanding programs, available as COTS, modified off-the-shelf, or fully custom.
      </p>
    </div>
  </div>

  <!-- Product Families Overview -->
  <section style="border-bottom: 1px solid var(--border-subtle); padding-block: 0;">
    <div style="display: grid; grid-template-columns: repeat(4, 1fr);">
      {[
        { label: 'Motor Controllers', img: '/images/cards/card-tmc.png' },
        { label: 'Flight Computers & FTS', img: '/images/cards/card-comet.png' },
        { label: 'I/O & Power Distribution', img: '/images/cards/card-io-compute.png' },
        { label: 'Power & Batteries', img: '/images/cards/card-power-batteries.png' },
      ].map(({ label, img }) => (
        <div style="position: relative; overflow: hidden; aspect-ratio: 3/2; border-right: 1px solid var(--border-subtle);">
          <img src={img} alt={label} loading="lazy" style="position: absolute; inset: 0; width: 100%; height: 100%; object-fit: cover; filter: grayscale(0.4) brightness(0.45);" />
          <div style="position: absolute; bottom: 0; left: 0; right: 0; padding: 1rem; background: linear-gradient(to top, oklch(8% 0.02 245 / 0.85), transparent); font-family: var(--font-mono); font-size: 0.65rem; letter-spacing: 0.1em; text-transform: uppercase; color: var(--ink-2);">{label}</div>
        </div>
      ))}
    </div>
  </section>

  <!-- Product Sections by Category -->
  {categories.map((cat) => (
    <section class="section" id={cat.toLowerCase().replace(/\W+/g, '-')}>
      <div class="container">
        {categoryBanners[cat] && (
          <div class="category-banner-wrap">
            <img src={categoryBanners[cat]} alt="" aria-hidden="true" />
            <div class="category-banner-content">
              <div class="section-label">{cat}</div>
              <h2>{cat}</h2>
            </div>
          </div>
        )}
        {!categoryBanners[cat] && (
          <div style="margin-bottom: 2.5rem; padding-bottom: 1.5rem; border-bottom: 1px solid var(--border-subtle);">
            <div class="section-label">{cat}</div>
            <h2>{cat}</h2>
          </div>
        )}

        <div class="product-grid">
          {byCategory[cat].map((product) => (
            <a href={`/products/${product.id}`} class="product-card">
              {productCardImages[product.id] && (
                <div class="product-card-img-wrap">
                  <img src={productCardImages[product.id]} alt={product.data.title} class="product-card-img" loading="lazy" />
                </div>
              )}
              <div class="product-card-category">{product.data.category}</div>
              <div class="product-card-name">{product.data.title}</div>
              <p class="product-card-tagline">{product.data.tagline}</p>
              <div class="product-card-specs">
                {product.data.keySpecs.slice(0, 4).map((spec) => (
                  <div class="product-card-spec">
                    <span class="product-card-spec-label">{spec.label}</span>
                    <span class="product-card-spec-value">{spec.value}</span>
                  </div>
                ))}
              </div>
              <div class="product-card-link">Full specifications →</div>
            </a>
          ))}
        </div>
      </div>
    </section>
  ))}

  <!-- Custom Solutions CTA -->
  <section style="background: var(--surface); border-top: 1px solid var(--border-subtle); padding-block: clamp(3rem, 6vw, 6rem);">
    <div class="container" style="display: grid; grid-template-columns: 1fr auto; gap: 3rem; align-items: center;">
      <div>
        <div class="section-label">Not seeing what you need?</div>
        <h2 style="margin-bottom: 0.75rem; font-size: clamp(1.5rem, 1.2rem + 1.2vw, 2.25rem);">COTS, MOTS, or fully custom</h2>
        <p style="color: var(--ink-2); max-width: 56ch;">
          Every product in our catalog is also a starting point for a MOTS or custom solution. Our team can walk you through the tradeoffs for your specific requirements: voltage, current, packaging, and environment.
        </p>
      </div>
      <div style="display: flex; flex-direction: column; gap: 0.75rem; align-items: flex-start; flex-shrink: 0;">
        <a href="/capabilities" class="btn btn-outline">Our Capabilities</a>
        <a href="/contact" class="btn btn-primary">Talk to Sales</a>
      </div>
    </div>
  </section>
</BaseLayout>
