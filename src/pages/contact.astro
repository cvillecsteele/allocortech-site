---
import BaseLayout from '@/layouts/BaseLayout.astro';
---

<BaseLayout
  title="Contact"
  description="Get in touch with Allocortech. Talk to our sales team about motor controllers, avionics, and custom power electronics solutions."
>
  <div class="page-hero">
    <div class="container">
      <div class="section-label">Contact</div>
      <h1 style="margin-bottom: 1rem;">Get in touch</h1>
      <p class="lead" style="max-width: 52ch;">
        Is your company looking for a way to accelerate next-gen vehicle development? We want to help.
      </p>
    </div>
  </div>

  <section class="section">
    <div class="container">
      <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 6rem; align-items: start;">

        <!-- Form -->
        <div>
          <div class="section-label" style="margin-bottom: 2rem;">Send us a message</div>
          <form
            name="contact"
            method="POST"
            action="/contact?success=true"
            style="display: flex; flex-direction: column; gap: 1.5rem;"
          >
            <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 1rem;">
              <div class="form-group">
                <label for="name">Full Name</label>
                <input type="text" id="name" name="name" required placeholder="Jane Smith" />
              </div>
              <div class="form-group">
                <label for="email">Email Address</label>
                <input type="email" id="email" name="email" required placeholder="jane@company.com" />
              </div>
            </div>

            <div class="form-group">
              <label for="phone">Phone Number (optional)</label>
              <input type="tel" id="phone" name="phone" placeholder="+1 (555) 000-0000" />
            </div>

            <div class="form-group">
              <label for="interest">Product Interest</label>
              <select id="interest" name="interest">
                <option value="">Select a product area...</option>
                <option value="motor-controllers">Motor Controllers (Taurus Family)</option>
                <option value="clio">Clio / Dauphine: I/O &amp; Compute</option>
                <option value="comet">Comet FTS: Flight Termination</option>
                <option value="atlas">Atlas: Flight Computer</option>
                <option value="hornet">Hornet: Air Data Sensors</option>
                <option value="lohner">Lohner: Smart Battery</option>
                <option value="battery-custom">Custom Battery / BMS</option>
                <option value="multiple">Multiple Products / Full System</option>
                <option value="custom">Custom / MOTS Requirement</option>
                <option value="other">Other / Not Sure</option>
              </select>
            </div>

            <div class="form-group">
              <label for="message">Additional Details</label>
              <textarea
                id="message"
                name="message"
                placeholder="Tell us about your vehicle platform, power requirements, timeline, and any other relevant context..."
                style="min-height: 150px;"
              ></textarea>
            </div>

            <button type="submit" class="btn btn-primary" style="align-self: flex-start; padding: 0.85rem 2rem; font-size: 0.9rem;">
              Send Message
            </button>
          </form>
        </div>

        <!-- Contact info + details -->
        <div>
          <div class="section-label" style="margin-bottom: 2rem;">Contact information</div>

          <div style="display: flex; flex-direction: column; gap: 2rem; margin-bottom: 3rem;">
            <div>
              <div class="footer-contact-label" style="margin-bottom: 0.4rem;">Sales Inquiries</div>
              <a href="mailto:sales@allocor.tech" style="font-size: 1.1rem; color: var(--ink); font-weight: 500; transition: color 0.15s;"
                onmouseover="this.style.color='var(--amber)'" onmouseout="this.style.color='var(--ink)'">
                sales@allocor.tech
              </a>
            </div>

            <div>
              <div class="footer-contact-label" style="margin-bottom: 0.4rem;">Phone</div>
              <a href="tel:+14342183345" style="font-size: 1.1rem; color: var(--ink); font-weight: 500; transition: color 0.15s;"
                onmouseover="this.style.color='var(--amber)'" onmouseout="this.style.color='var(--ink)'">
                (434) 218-3345
              </a>
            </div>

            <div>
              <div class="footer-contact-label" style="margin-bottom: 0.4rem;">Address</div>
              <address style="font-style: normal; font-size: 1rem; color: var(--ink); line-height: 1.6;">
                440 N Commerce Ave<br />
                Waynesboro, VA 22980
              </address>
            </div>
          </div>

          <div style="padding: 2rem; background: var(--surface); border: 1px solid var(--border-subtle);">
            <div class="section-label" style="margin-bottom: 1.25rem;">What to expect</div>
            <div style="display: flex; flex-direction: column; gap: 1rem;">
              {[
                ['Initial response', 'Within 1 business day'],
                ['Spec review (new customers)', 'Complimentary'],
                ['MOTS delivery', '8–12 weeks typical'],
                ['Custom feasibility assessment', 'Available on request'],
              ].map(([label, value]) => (
                <div style="display: flex; justify-content: space-between; align-items: center; padding-bottom: 1rem; border-bottom: 1px solid var(--border-subtle);">
                  <span style="font-size: 0.8rem; color: var(--ink-2);">{label}</span>
                  <span style="font-family: var(--font-mono); font-size: 0.78rem; color: var(--amber);">{value}</span>
                </div>
              ))}
            </div>
          </div>
        </div>

      </div>
    </div>
  </section>
</BaseLayout>
